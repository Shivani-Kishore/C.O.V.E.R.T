# C.O.V.E.R.T Production Environment Variables
# Copy to .env and fill in real values before deploying.

# ===== Application =====
ENVIRONMENT=production
DEBUG=false

# ===== Backend API =====
SECRET_KEY=your-random-256-bit-secret-key-here
API_V1_PREFIX=/api/v1

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://covert_user:STRONG_PASSWORD@your-db-host:5432/covert_db
DB_ECHO=false

# ===== Redis =====
REDIS_URL=redis://your-redis-host:6379/0

# ===== IPFS / Pinata =====
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# ===== Blockchain (Base Mainnet) =====
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
PRIVATE_KEY=your-deployer-private-key-here
AUTOMATION_PRIVATE_KEY=your-automation-wallet-private-key-here

# ===== Smart Contract Addresses (fill after deployment) =====
COMMITMENT_REGISTRY_ADDRESS=0x...
DAILY_ANCHOR_ADDRESS=0x...
COV_CREDITS_ADDRESS=0x...
COVERT_BADGES_ADDRESS=0x...
COVERT_PROTOCOL_ADDRESS=0x...

# ===== CORS =====
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===== Rate Limiting =====
RATE_LIMIT_SUBMISSIONS=10
RATE_LIMIT_GENERAL=100

# ===== File Upload =====
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.mp4,.zip

# ===== Monitoring =====
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=WARNING

# ===== Frontend (Vite) =====
VITE_DEV_MODE=false
VITE_API_URL=https://api.your-domain.com
VITE_RPC_URL=https://mainnet.base.org
VITE_CHAIN_ID=8453
VITE_COMMITMENT_REGISTRY_ADDRESS=0x...
VITE_DAILY_ANCHOR_ADDRESS=0x...
VITE_COV_CREDITS_ADDRESS=0x...
VITE_COVERT_BADGES_ADDRESS=0x...
VITE_COVERT_PROTOCOL_ADDRESS=0x...
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
VITE_PINATA_API_KEY=your-pinata-api-key
VITE_PINATA_SECRET_KEY=your-pinata-secret-key
