# C.O.V.E.R.T Environment Variables Example
# Copy this file to .env and fill in your values

# ===== Application =====
ENVIRONMENT=development
DEBUG=true

# ===== Backend API =====
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://covert_user:covert_password@localhost:5432/covert_db
DB_ECHO=false

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== IPFS =====
IPFS_API_URL=/ip4/127.0.0.1/tcp/5001
IPFS_GATEWAY_URL=http://localhost:8080
PINATA_API_KEY=
PINATA_SECRET_KEY=
WEB3_STORAGE_TOKEN=

# ===== Blockchain (Local Anvil) =====
RPC_URL=http://localhost:8545
CHAIN_ID=31337
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ===== Smart Contract Addresses (Fill after deployment) =====
COMMITMENT_REGISTRY_ADDRESS=
DAILY_ANCHOR_ADDRESS=
REPUTATION_SBT_ADDRESS=

# ===== Rate Limiting =====
RATE_LIMIT_SUBMISSIONS=10
RATE_LIMIT_GENERAL=100

# ===== File Upload =====
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.mp4,.zip

# ===== Monitoring =====
SENTRY_DSN=
LOG_LEVEL=INFO

# ===== Frontend =====
VITE_API_URL=http://localhost:8000
VITE_RPC_URL=http://localhost:8545
VITE_CHAIN_ID=31337
VITE_COMMITMENT_REGISTRY_ADDRESS=
VITE_DAILY_ANCHOR_ADDRESS=
VITE_IPFS_GATEWAY=http://localhost:8080

# ===== Testnet (Base Sepolia) =====
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# BASESCAN_API_KEY=

# ===== Mainnet (Base) =====
# BASE_RPC_URL=https://mainnet.base.org
# BASESCAN_API_KEY=
