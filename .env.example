# C.O.V.E.R.T Environment Variables Example
# Copy this file to .env and fill in your values

# ===== Application =====
ENVIRONMENT=development
DEBUG=true

# ===== Backend API =====
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://covert_user:covert_password@localhost:5432/covert_db
DB_ECHO=false

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== IPFS / Pinata =====
IPFS_API_URL=/ip4/127.0.0.1/tcp/5001
IPFS_GATEWAY_URL=http://localhost:8080
PINATA_API_KEY=
PINATA_SECRET_KEY=
WEB3_STORAGE_TOKEN=

# ===== Blockchain (Local Anvil) =====
RPC_URL=http://localhost:8545
CHAIN_ID=31337
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ===== Smart Contract Addresses (Fill after deployment) =====
COMMITMENT_REGISTRY_ADDRESS=
DAILY_ANCHOR_ADDRESS=
COV_CREDITS_ADDRESS=
COVERT_BADGES_ADDRESS=
COVERT_PROTOCOL_ADDRESS=

# ===== Automation (for reviewer role sync) =====
AUTOMATION_PRIVATE_KEY=

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Rate Limiting =====
RATE_LIMIT_SUBMISSIONS=10
RATE_LIMIT_GENERAL=100

# ===== File Upload =====
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.mp4,.zip

# ===== Monitoring =====
SENTRY_DSN=
LOG_LEVEL=INFO

# ===== Frontend (Vite) =====
VITE_DEV_MODE=true
VITE_API_URL=http://localhost:8000

# Note: VITE_RPC_URL and VITE_CHAIN_ID are reserved for future use.
# The frontend currently reads chain config from the connected MetaMask wallet.
VITE_RPC_URL=https://sepolia.base.org
VITE_CHAIN_ID=84532

VITE_COMMITMENT_REGISTRY_ADDRESS=
VITE_DAILY_ANCHOR_ADDRESS=
VITE_COV_CREDITS_ADDRESS=
VITE_COVERT_BADGES_ADDRESS=
VITE_COVERT_PROTOCOL_ADDRESS=
VITE_IPFS_GATEWAY=http://localhost:8080
VITE_IPFS_API=                        # Local IPFS API URL (leave empty for production)
VITE_NFT_STORAGE_TOKEN=               # NFT.Storage API token — get free at nft.storage
VITE_WEB3_STORAGE_TOKEN=              # web3.storage token (optional fallback)
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_KEY=
