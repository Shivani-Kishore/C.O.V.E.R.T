# C.O.V.E.R.T Frontend Environment Variables

# ===== API Configuration =====
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1

# ===== Blockchain Configuration =====
VITE_RPC_URL=http://localhost:8545
VITE_CHAIN_ID=31337
VITE_CHAIN_NAME=Anvil Local

# ===== Smart Contract Addresses =====
VITE_COMMITMENT_REGISTRY_ADDRESS=
VITE_DAILY_ANCHOR_ADDRESS=
VITE_REPUTATION_SBT_ADDRESS=

# ===== IPFS Configuration =====
VITE_IPFS_GATEWAY=http://localhost:8080
VITE_IPFS_API=/ip4/127.0.0.1/tcp/5001

# ===== Application Settings =====
VITE_APP_NAME=C.O.V.E.R.T
VITE_MAX_FILE_SIZE=104857600
VITE_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.mp4,.zip

# ===== Feature Flags =====
VITE_ENABLE_ZK_PROOFS=false
VITE_ENABLE_DISPUTE_RESOLUTION=false
VITE_ENABLE_REPUTATION=false
